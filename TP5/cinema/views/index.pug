extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Listagem de filmes

      a.w3-btn.w3-teal.w3-margin-top(href="/atores/") Listagem de atores
      a.w3-btn.w3-teal.w3-margin-top(href="/generos/") Listagem de géneros
    
    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th Id
          th Título
          th Ano
          th Género
          th Cast
        each f in list
          tr
            td
              a.w3-btn.w3-round.w3-blue-grey.w3-small(href=`/filmes/${f.id}`) #{f.id}

            td= f.title
            td= f.year
            td= f.genres.join(', ') 
            td= f.cast.join(', ') 
              