extends layout 

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1= filme.title + " (" + filme.year + ")"

    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th Título
          td= filme.title
        tr
          th Ano
          td= filme.year
        tr
          th Géneros
          td= filme.genres.join(', ')

      .w3-container.w3-teal.w3-margin-top
        h3= "Cast:"

      ul
        each c in filme.cast
          li= c    

    a.w3-btn.w3-grey.w3-margin-top.w3-margin-left(href="/filmes/") Voltar