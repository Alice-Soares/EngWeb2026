extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Listagem de gêneros

      a.w3-btn.w3-teal.w3-margin-top(href="/filmes/") Listagem de filmes
      a.w3-btn.w3-teal.w3-margin-top(href="/atores/") Listagem de atores
    
    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th Id
          th Género
          th Número de filmes
        each f in list
          tr
            td
              a.w3-btn.w3-round.w3-blue-grey.w3-small(href=`/generos/${f._id}`) #{f.id}

            td= f.nome
            td= f.filmes.length 